{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Machine-readable mirror of context-schema.md (the authoritative document). Update both in the same commit. Consumers: context-sync, future check tooling, agents that prefer structured data.",
  "title": ".context/ directory schema",
  "coreVersion": "0.2.0",
  "zones": {
    "core": {
      "path": ".context/core/",
      "owner": "package",
      "agentWritable": false,
      "sync": "whole-tree, version-stamped, via context-sync update only"
    },
    "memory": {
      "path": ".context/memory/",
      "owner": "project",
      "agentWritable": true,
      "sync": "never"
    }
  },
  "rootFiles": {
    ".context/README.md": {
      "mode": "generated",
      "template": "core/templates/context-README.md",
      "refreshedOnCoreUpdate": true
    },
    ".context/kickoff.md": {
      "mode": "generated",
      "template": "core/templates/kickoff.md",
      "refreshedOnCoreUpdate": false,
      "note": "project data; regenerated by a session only when the template materially changes"
    },
    "AGENTS.md": {
      "mode": "generated",
      "template": "core/templates/AGENTS.md",
      "location": "project root",
      "aliases": ["CLAUDE.md", ".github/copilot-instructions.md"],
      "refreshedOnCoreUpdate": true
    }
  },
  "memoryFiles": {
    "agents/sessions.md":      { "mode": "append-only",      "scope": "project" },
    "tasks/current.md":        { "mode": "overwrite",        "scope": "project", "note": "doubles as the one-agent-per-repo lock" },
    "tasks/backlog.md":        { "mode": "append-only",      "scope": "project" },
    "plans/decisions.md":      { "mode": "append-only",      "scope": "project" },
    "flaws/log.md":            { "mode": "append-only",      "scope": "project", "flowsTo": "package" },
    "flaws/README.md":         { "mode": "generated",        "scope": "project" },
    "inefficiencies/log.md":   { "mode": "append-only",      "scope": "project" },
    "reviews/README.md":       { "mode": "generated",        "scope": "project" },
    "reviews/YYYY-MM-DD-*.md": { "mode": "new-file-per-session", "scope": "project", "commitPrefix": "docs(review):" },
    "workflows/active.md":     { "mode": "overwrite",        "scope": "project", "note": "protocol field is recorded 'by agent type', naming BOTH editions — never a single edition" },
    "system/environments.md":  { "mode": "update-in-place",  "scope": "machine", "keyedBy": "Identify by" },
    "system/ai-models.md":     { "mode": "update-in-place",  "scope": "agent-model" },
    "user/identity.md":        { "mode": "update-in-place",  "scope": "user" },
    "user/preferences.md":     { "mode": "update-in-place",  "scope": "user", "note": "every bullet carries provenance" },
    "overrides/rules.md":      { "mode": "update-in-place",  "scope": "project", "precedence": "beats the edition, except secret-handling and append-only rules" },
    "core.lock":               { "mode": "overwrite",        "scope": "project", "writer": "context-sync", "note": "last-known-good core version" },
    "secrets/<slug>":          { "mode": "local-only",       "scope": "machine", "tracked": false },
    "secrets/README.md":       { "mode": "generated",        "scope": "project" },
    "secrets/.gitignore":      { "mode": "generated",        "scope": "project" }
  },
  "factScopes": ["project", "agent-type", "machine", "agent-model", "user"],
  "bindingRules": {
    "editionSelection": "function of the running agent's type at session start; never read from memory",
    "machineBlocks": "apply only where the block's 'Identify by' matches",
    "credentialFlows": "agent-type facts; PAT steps exist only in the cloud edition",
    "appendOnly": "corrections are appended, never edited in; byte-identical duplicates may be removed with a note",
    "secrets": "values only under memory/secrets/, never in tracked files, never echoed",
    "coreReadOnly": "no agent writes under .context/core/ in a project repo, ever"
  },
  "commitPrefixes": {
    "memory": "chore(context):",
    "reviews": "docs(review):",
    "coreUpdate": "chore(context): update core to <version>"
  }
}
